# Select the same variables used in GUIDE
cols_to_keep <- c(
"host_response_rate", "host_acceptance_rate", "host_is_superhost",
"accommodates", "beds", "price", "minimum_nights", "maximum_nights",
"has_availability", "number_of_reviews", "review_scores_rating",
"instant_bookable", "reviews_per_month"
)
df_r <- airbnb[, cols_to_keep]
# Clean price: remove $ and commas, convert to numeric, log-transform
df_r$price <- as.numeric(gsub("[$,]", "", df_r$price))
df_r$price <- log(df_r$price)
# Clean rate columns: remove % and scale to [0,1]
df_r$host_response_rate  <- as.numeric(gsub("%", "", df_r$host_response_rate))  / 100
df_r$host_acceptance_rate <- as.numeric(gsub("%", "", df_r$host_acceptance_rate)) / 100
# Convert boolean columns to factors
bool_cols <- c("host_is_superhost", "has_availability", "instant_bookable")
df_r[bool_cols] <- lapply(df_r[bool_cols], as.factor)
# Drop rows with any missing values
df_r <- na.omit(df_r)
# Train/test split (80/20, matching Python seed as closely as possible)
set.seed(42)
n <- nrow(df_r)
train_idx <- sample(seq_len(n), size = floor(0.8 * n))
train_r <- df_r[ train_idx, ]
test_r  <- df_r[-train_idx, ]
ct <- ctree(price ~ ., data = train_r)
# Variable importance: count how many times each variable is used as a split
used_vars <- as.character(unlist(lapply(nodes(ct, unique(where(ct))),
function(n) if (!is.null(n$psplit)) n$psplit$variableName else NULL)))
# Variable importance: count split variables by walking the tree nodes
node_list <- as.list(ct@tree)
extract_splits <- function(node) {
if (is.null(node$psplit)) return(character(0))
c(node$psplit$variableName,
extract_splits(node$left),
extract_splits(node$right))
}
used_vars <- extract_splits(ct@tree)
importance_ct <- sort(table(used_vars), decreasing = TRUE)
print(importance_ct)
imp_df <- as.data.frame(importance_ct)
colnames(imp_df) <- c("Variable", "Count")
imp_df$Normalized <- (imp_df$Count / max(imp_df$Count)) * 100
imp_df <- imp_df[order(imp_df$Normalized), ]
top_k <- 3
imp_df$Color <- ifelse(
imp_df$Normalized >= sort(imp_df$Normalized, decreasing = TRUE)[top_k],
"red", "gray"
)
par(mar = c(4, 10, 3, 2))
barplot(
imp_df$Normalized,
names.arg = imp_df$Variable,
horiz = TRUE,
las = 1,
col = imp_df$Color,
xlab = "Normalized Split Count (0-100)",
main = "Feature Importance (ctree)",
cex.names = 0.8
)
knitr::opts_chunk$set(echo = TRUE)
knitr::include_graphics("correlation_heatmap.png")
knitr::include_graphics("price_distribution.png")
knitr::include_graphics("cropped_tree.png")
library(party)
library(dplyr)
# Load the cleaned dataset exported for GUIDE
airbnb <- read.csv("./data/train_regression.csv", stringsAsFactors = FALSE)
# Select the same variables used in GUIDE
cols_to_keep <- c(
"host_response_rate", "host_acceptance_rate", "host_is_superhost",
"accommodates", "beds", "price", "minimum_nights", "maximum_nights",
"has_availability", "number_of_reviews", "review_scores_rating",
"instant_bookable", "reviews_per_month"
)
df_r <- airbnb[, cols_to_keep]
# Clean price: remove $ and commas, convert to numeric, log-transform
df_r$price <- as.numeric(gsub("[$,]", "", df_r$price))
df_r$price <- log(df_r$price)
# Clean rate columns: remove % and scale to [0,1]
df_r$host_response_rate  <- as.numeric(gsub("%", "", df_r$host_response_rate))  / 100
df_r$host_acceptance_rate <- as.numeric(gsub("%", "", df_r$host_acceptance_rate)) / 100
# Convert boolean columns to factors
bool_cols <- c("host_is_superhost", "has_availability", "instant_bookable")
df_r[bool_cols] <- lapply(df_r[bool_cols], as.factor)
# Drop rows with any missing values
df_r <- na.omit(df_r)
# Train/test split (80/20, matching Python seed as closely as possible)
set.seed(42)
n <- nrow(df_r)
train_idx <- sample(seq_len(n), size = floor(0.8 * n))
train_r <- df_r[ train_idx, ]
test_r  <- df_r[-train_idx, ]
{r ctree-fit, message=FALSE, warning=FALSE}
