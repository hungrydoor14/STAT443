df_sub <- df[df$neighbourhood_cleansed %in% top_neigh, ]
boxplot(log(price) ~ neighbourhood_cleansed, data = df_sub,
main = "Log Price by Neighborhood",
las = 2)
plot(df$number_of_reviews, log(df$price),
